            },
            "url": {
              "raw": "{{baseUrl}}/api/bff/recovery/otp/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bff",
                "recovery",
                "otp",
                "verify"
              ]
            },
            "description": "Verify OTP sent during account recovery process."
          },
          "response": []
        }
      ]
