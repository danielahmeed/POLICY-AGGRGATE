{
  "info": {
    "name": "MyPolicy BFF APIs",
    "description": "Complete API testing collection for MyPolicy Backend For Frontend (BFF) service. Includes all authentication, signup, recovery, dashboard, profile, policies, and help endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth & Signup",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerIdOrUserId\": \"Amit Ramesh Kulkarni\",\n  \"password\": \"AKCPK1123L\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bff/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bff",
                "auth",
                "login"
              ]
            },
            "description": "Login with customer name and PAN. Returns JWT token for use in subsequent requests."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('token', jsonData.token);",
                  "    pm.environment.set('customerId', jsonData.customer.customerId);",
                  "    console.log('Token and customerId saved to environment');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"mobileNumber\": \"919876543210\",\n  \"dateOfBirth\": \"1990-05-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bff/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bff",
                "signup"
              ]
            },
            "description": "Register a new customer. Returns customerId for OTP verification."
          },
          "response": []
        },
        {
          "name": "Verify Signup OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"919876543210\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bff/signup/verify-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bff",
                "signup",
                "verify-otp"
              ]
            },
            "description": "Verify OTP sent to mobile number during signup."
          },
          "response": []
        },
        {
          "name": "Create Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bff/signup/create-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bff",
                "signup",
                "create-password"
              ]
            },
            "description": "Create password for new customer account after OTP verification."
          },
          "response": []
        }
      ]
    },
